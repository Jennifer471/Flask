@app.route("/add", methods=["POST"])
def add():
    data = request.json

    conn = get_db_connection()
    cursor = conn.cursor()
    cursor.execute("""
        INSERT INTO Database (Variable1, Variable2, Variable3, Variable4)
        VALUES (?, ?, ?, ?)
    """, (
        data['Variable1'],          
        data['Variable2'],   
        data['Variable3'],      
        data['Variable4']          
    ))

    conn.commit()
    conn.close()
    return jsonify({"message": " added successfully"})

